# Python virtual environment
.venv/
__pycache__/
*.pyc

# Terraform: provider plugins + local state (never commit)
**/.terraform/
*.tfstate
*.tfstate.backup

# Terraform: environment values / secrets — commit the .example instead
*.tfvars
!*.tfvars.example

# Credentials / secrets
*.env
.env
service-account-*.json

# dbt (used in a later milestone)
target/
dbt_packages/
logs/

# Airflow — never commit credentials or local logs
airflow/gcp/
airflow/logs/
standalone_admin_password.txt
